{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel.rs/master/examples/example_json/schema.json",
  "productName": "mdcast",
  "version": "0.1.4",
  "identifier": "com.mdcast.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "mdcast",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  }
}
